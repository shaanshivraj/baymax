<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/chat_bg"
    android:elevation="20dp">

    <!-- ── Header ──────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_ai"
            android:background="@drawable/bubble_bg"
            android:padding="6dp"
            android:layout_marginEnd="10dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PhoneAI"
            android:textColor="#F1F0FF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnQuitApp"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_power"
            android:tint="#EF4444"
            android:layout_marginEnd="8dp"
            android:contentDescription="Quit App" />

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_close"
            android:contentDescription="Close" />
    </LinearLayout>

    <!-- Status bar (recording / thinking) -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#A09EC0"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingBottom="6dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#12FFFFFF" />

    <!-- ── Messages ─────────────────────────────────────────────── -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/messagesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp" />
    </ScrollView>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#12FFFFFF" />

    <!-- ── Input Area ───────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/input_area_bg"
        android:paddingStart="12dp"
        android:paddingEnd="6dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <EditText
            android:id="@+id/etInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Message PhoneAI..."
            android:textColorHint="#5F5D80"
            android:textColor="#F1F0FF"
            android:textSize="14sp"
            android:background="@null"
            android:maxLines="4"
            android:inputType="textMultiLine|textCapSentences"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <!-- Mic button: hold to record -->
        <ImageButton
            android:id="@+id/btnMic"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_mic"
            android:tint="#A09EC0"
            android:layout_marginStart="4dp"
            android:contentDescription="Hold to record voice" />

        <!-- Send text button -->
        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/send_btn_bg"
            android:src="@drawable/ic_send"
            android:layout_marginStart="4dp"
            android:contentDescription="Send" />

    </LinearLayout>

</LinearLayout>
