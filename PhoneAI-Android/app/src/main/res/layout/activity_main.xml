<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0A0A0F"
    android:padding="32dp">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_ai"
        android:background="@drawable/bubble_bg"
        android:padding="18dp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PhoneAI"
        android:textColor="#F1F0FF"
        android:textSize="34sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-bold"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Floating AI Assistant"
        android:textColor="#A09EC0"
        android:textSize="15sp"
        android:layout_marginBottom="40dp" />

    <!-- Customization Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#13131A"
        android:padding="16dp"
        android:layout_marginBottom="24dp"
        android:elevation="2dp"
        android:backgroundTint="#13131A">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Customize Baymax"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvSizeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bubble Size: Medium"
            android:textColor="#A09EC0"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <SeekBar
            android:id="@+id/seekSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="36"
            android:progressTint="#7C3AED"
            android:thumbTint="#7C3AED" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap below to get started"
        android:textColor="#A09EC0"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <Button
        android:id="@+id/btnStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🚀  Launch Floating Ball"
        android:backgroundTint="#7C3AED"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:paddingStart="36dp"
        android:paddingEnd="36dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="• Grant 'Draw over other apps' permission\n• Grant microphone access for voice input\n• Ball floats above all your apps\n• Tap ball to open chat\n• Hold 🎤 mic button to speak (Whisper AI)"
        android:textColor="#5F5D80"
        android:textSize="13sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.6" />

</LinearLayout>
