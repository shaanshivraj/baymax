<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bubbleRoot"
    android:layout_width="66dp"
    android:layout_height="66dp"
    android:elevation="10dp">

    <ImageView
        android:id="@+id/bubbleIcon"
        android:layout_width="66dp"
        android:layout_height="66dp"
        android:src="@drawable/ic_baymax"
        android:scaleType="fitCenter"
        android:contentDescription="Baymax AI" />

    <ImageView
        android:id="@+id/btnCloseBubble"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-4dp"
        android:layout_marginEnd="-4dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:background="@drawable/bubble_bg"
        android:backgroundTint="#FF4444"
        android:padding="4dp"
        android:elevation="12dp"
        android:contentDescription="Close Bubble" />

</FrameLayout>
